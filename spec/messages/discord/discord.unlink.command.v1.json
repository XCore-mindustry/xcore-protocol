{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:xcore:protocol:messages:discord:discord.unlink.command:v1",
  "title": "DiscordUnlinkCommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["messageType", "messageVersion", "player", "discord", "requestedBy", "server", "requestedAt"],
  "properties": {
    "messageType": {
      "const": "discord.unlink.command"
    },
    "messageVersion": {
      "const": 1
    },
    "player": {
      "$ref": "urn:xcore:protocol:shared:types:player-ref:v1"
    },
    "discord": {
      "$ref": "urn:xcore:protocol:shared:types:discord-identity-ref:v1"
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "server": {
      "type": "string",
      "minLength": 1
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
