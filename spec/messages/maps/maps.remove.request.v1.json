{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:xcore:protocol:messages:maps:maps.remove.request:v1",
  "title": "MapsRemoveRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["messageType", "messageVersion", "server", "fileName"],
  "properties": {
    "messageType": {
      "const": "maps.remove.request"
    },
    "messageVersion": {
      "const": 1
    },
    "server": {
      "type": "string",
      "minLength": 1
    },
    "fileName": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.[mM][sS][aA][vV]$"
    }
  }
}
