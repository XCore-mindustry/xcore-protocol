{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:xcore:protocol:messages:maps:maps.load.command:v1",
  "title": "MapsLoadCommandV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["messageType", "messageVersion", "server", "files"],
  "properties": {
    "messageType": {
      "const": "maps.load.command"
    },
    "messageVersion": {
      "const": 1
    },
    "server": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "urn:xcore:protocol:shared:types:map-file-source:v1"
      }
    }
  }
}
